{
  "name": "knewtab",
  "short_name": "knewtab",
  "version": "0.1.5",
  "browser_specific_settings": {
    "gecko": {
      "id": "{bb9cfae3-9ac6-4c72-b90b-71814ab7d780}",
      "strict_min_version": "143.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "minimum_chrome_version": "104",
  "manifest_version": 3,
  "description": "Simple new tab page.",
  "icons": {
    "128": "icons/icon_128.png",
    "48": "icons/icon_48.png",
    "16": "icons/icon_16.png"
  },
  "permissions": ["bookmarks", "favicon", "fontSettings", "sessions"],
  "optional_host_permissions": ["file:///"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "newtab.html?options",
    "open_in_tab": true
  }
}
